# Host for local dev
HOST=localhost

# Ports
BACKEND_PORT=8080
AGENT_PORT=8090
FRONTEND_PORT=5173
KAFKA_PORT=9092
OLLAMA_PORT=11434

# URLs
BACKEND_URL=http://localhost:8080
AGENT_URL=http://localhost:8090
FRONTEND_URL=http://localhost:5173
OLLAMA_URL=http://localhost:11434

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_JOBS_TOPIC=compile.jobs
KAFKA_RESULTS_TOPIC=compile.results

# Agent
OLLAMA_MODEL=llama3.2
MAX_COMPILE_RETRIES=3
